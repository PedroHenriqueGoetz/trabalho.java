<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Editar Produto</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="container">

    <h1>Editar Produto</h1>

    <form action="/produtos/editar/<%= produto.id %>" method="POST">
        <input name="nome" value="<%= produto.nome %>" required>
        <input name="preco" value="<%= produto.preco %>" required>
        <button type="submit">Salvar</button>
    </form>

    <div class="links">
        <a href="/produtos">Voltar</a>
        <a href="/">Home</a>
    </div>

</div>

</body>
</html>